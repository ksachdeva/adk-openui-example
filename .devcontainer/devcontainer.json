{
  "name": "adk-openui-example",
  "dockerFile": "Dockerfile",
  "containerEnv": {
    "LANG": "en_US.UTF-8",
    "NODE_EXTRA_CA_CERTS": "/usr/local/share/ca-certificates/cloudflare.crt",
    "APP_HOST_WORKSPACE_FOLDER": "${localWorkspaceFolder}",
    "APP_DEV_CONTAINER_WORKSPACE_FOLDER": "${containerWorkspaceFolder}"
  },
  "remoteEnv": {
    "UV_LINK_MODE": "copy",
    "UV_SYSTEM_CERTS": "true"
  },
  "runArgs": [
    "--add-host=host.docker.internal:host-gateway"
  ],
  "customizations": {
    "vscode": {
      "settings": {
        "[python]": {
          "editor.tabSize": 4,
          "editor.insertSpaces": true,
          "editor.formatOnSave": true,
          "editor.defaultFormatter": "charliermarsh.ruff",
          "testing.unittestEnabled": false,
          "testing.pytestEnabled": true,
          "testing.pytestArgs": ["tests"],
          "defaultInterpreterPath": "./venv/bin/python"
        },
        "python.terminal.activateEnvironment": false,
        "python-envs.terminal.autoActivationType": "off",
        "files.exclude": {
          "**/.git": true,
          "**/.svn": true,
          "**/.hg": true,
          "**/CVS": true,
          "**/.DS_Store": true,
          "**/__pycache__": true,
          "**/.mypy_cache": true,
          "**/.pytest_cache": true,
          "**/.ruff_cache": true
        },
        "terminal.integrated.fontFamily": "Consolas, monospace",
        "terminal.integrated.defaultProfile.linux": "zsh",
        "mypy-type-checker.importStrategy": "fromEnvironment",
        "remote.autoForwardPorts": true,
        "remote.autoForwardPortsSource": "process"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.mypy-type-checker",
        "charliermarsh.ruff",
        "esbenp.prettier-vscode",
        "bierner.markdown-mermaid"
      ]
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installOhMyZshConfig": false,
      "configureZshAsDefaultShell": true
    },
    // Node
    "ghcr.io/devcontainers/features/node:2.0.0": {
      "version": "lts"
    },
    // TypeScript
    "ghcr.io/devcontainers-extra/features/typescript:2": {},
    // ts-node
    "ghcr.io/devcontainers-extra/features/ts-node:1": {},
    // Modern shell utils
    "ghcr.io/mikaello/devcontainer-features/modern-shell-utils:2.0.0": {},
    // uv
    "ghcr.io/jsburckhardt/devcontainer-features/uv:1": {},
    // docker-in-docker
    "ghcr.io/devcontainers/features/docker-in-docker:3.0.1": {
      "moby": false
    }
  },
  "mounts": [
    "source=devcontainer-zshhistory,target=/commandhistory,type=volume"
  ],
  "postCreateCommand": ["bash", ".devcontainer/scripts/post-create.sh"]
}
